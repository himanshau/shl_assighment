# Comma-separated browser origins (add your Vercel URL after deploy)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SHL catalog (public). Set USE_REMOTE_CATALOG=true to always download latest before ingest.
CATALOG_URL=https://tcp-us-prod-rnd.shl.com/voiceRater/shl-ai-hiring/shl_product_catalog.json
USE_REMOTE_CATALOG=false

GROQ_API_KEY=your_groq_key

DEEPGRAM_API_KEY=your_deepgram_key
DEEPGRAM_STT_MODEL=nova-2-general
DEEPGRAM_STT_LANGUAGE=multi
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
DEEPGRAM_TTS_ENCODING=mp3
DEEPGRAM_WS_BASE_URL=wss://api.deepgram.com/v1/listen
DEEPGRAM_REALTIME_ENDPOINTING_MS=500
DEEPGRAM_STREAM_KEEPALIVE_SECONDS=4
DEEPGRAM_CONNECT_RETRIES=3
DEEPGRAM_CONNECT_RETRY_DELAY_SECONDS=1.0
DEEPGRAM_RECONNECT_BASE_COOLDOWN_SECONDS=2.0
DEEPGRAM_RECONNECT_MAX_COOLDOWN_SECONDS=20.0
